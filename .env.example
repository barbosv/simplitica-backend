PORT=3000
NODE_ENV=development
STORAGE_BACKEND=postgres
DATABASE_URL=postgres://simplitica:simplitica@localhost:5432/simplitica
RUN_MIGRATIONS=true

APPLE_ENVIRONMENT=Sandbox
SIMPLI_INVOICE_BUNDLE_ID=co.simplitica.simpli-invoice
# SIMPLI_INVOICE_APP_APPLE_ID=

STRIPE_MODE=test
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_SECRET_KEY_LIVE=sk_live_...
# STRIPE_WEBHOOK_SECRET_LIVE=whsec_...
STRIPE_CONNECT_RETURN_URL=https://your-domain.com/stripe/return
STRIPE_CONNECT_REFRESH_URL=https://your-domain.com/stripe/refresh
STRIPE_PLATFORM_COUNTRY=US

# Optional — live Home Depot material pricing via OpenWeb Ninja direct API.
# Get your key at https://www.openwebninja.com/api/real-time-home-depot-data
# HOME_DEPOT_DATA_API_KEY=ak_...
# Optional — live Home Depot material pricing via RetailerAPI (tried first when both are set).
# Get your key at https://app.retailerapi.com/app/keys
# RETAILERAPI_KEY=rk_live_...
# RETAILERAPI_BASE_URL=https://api.retailerapi.com/v1
# BLS_API_KEY=your-bls-registration-key
# SIMPLITICA_CLIENT_API_KEY=hex-key-shared-with-ios-app-via-xcconfig
# HOME_DEPOT_DATA_API_BASE_URL=https://api.openwebninja.com/realtime-homedepot-data
# Leave HOME_DEPOT_DATA_API_HOST unset for direct OpenWeb Ninja.
# For RapidAPI instead, set HOME_DEPOT_DATA_API_HOST=real-time-home-depot-data.p.rapidapi.com

# Local file storage (no Postgres):
# STORAGE_BACKEND=file
# DATA_DIR=./data
